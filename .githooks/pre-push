#!/usr/bin/env bash
# Advisory changelog reminder (does not block). PR CI job "Changelog" still enforces this.
set -euo pipefail

ROOT="$(git rev-parse --show-toplevel)"
cd "$ROOT"

remote="${1:-origin}"
if git rev-parse --verify "$remote/main" >/dev/null 2>&1; then
  RANGE="$remote/main..HEAD"
elif git rev-parse --verify main >/dev/null 2>&1; then
  RANGE="main..HEAD"
else
  exit 0
fi

needs_changelog=0
while IFS= read -r line; do
  [[ -z "$line" ]] && continue
  if [[ "$line" =~ ^(feat|fix|perf)(\(|!|:|$) ]]; then
    needs_changelog=1
    break
  fi
done < <(git log --format='%s' "$RANGE" 2>/dev/null || true)

if [[ "$needs_changelog" -eq 0 ]]; then
  exit 0
fi

if git log --format='%H' "$RANGE" -- CHANGELOG.md | grep -q .; then
  exit 0
fi

if git diff --name-only "$RANGE" -- CHANGELOG.md | grep -q .; then
  exit 0
fi

cat >&2 <<'ERR'
pre-push: tip — this branch has feat/fix/perf commits but CHANGELOG.md was not updated.

  Add a bullet under ## [Unreleased] in CHANGELOG.md before opening the PR
  (CI "Changelog" job will fail the PR otherwise).

  (advisory only — push proceeds)
ERR

exit 0
