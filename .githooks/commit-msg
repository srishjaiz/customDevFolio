#!/usr/bin/env bash
# Advisory Conventional Commits check (does not block). CI does not enforce commit subjects;
# prefer type(scope): summary for a clear history. See .gitmessage / CONTRIBUTING.md.
set -euo pipefail

MSG_FILE="${1:-}"
if [[ -z "$MSG_FILE" || ! -f "$MSG_FILE" ]]; then
  exit 0
fi

subject="$(grep -vE '^\s*(#|$)' "$MSG_FILE" | head -n1 || true)"
if [[ -z "${subject// }" ]]; then
  exit 0
fi

if [[ "$subject" =~ ^Merge\  ]] || [[ "$subject" =~ ^Revert\  ]] || [[ "$subject" =~ ^fixup!\  ]] || [[ "$subject" =~ ^squash!\  ]]; then
  exit 0
fi

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .+'

if ! [[ "$subject" =~ $pattern ]]; then
  cat >&2 <<'ERR'
commit-msg: tip — prefer Conventional Commits for this repo:

  <type>(<optional-scope>): <summary>

  Types: feat fix docs style refactor perf test build ci chore revert
  Example: feat(cli): add domains subcommand

  (advisory only — commit proceeds; not enforced by CI)
ERR
fi

if (( ${#subject} > 100 )); then
  echo "commit-msg: tip — subject is ${#subject} chars (prefer ≤72)." >&2
fi

exit 0
