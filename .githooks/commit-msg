#!/usr/bin/env bash
# Enforce Conventional Commits (https://www.conventionalcommits.org/).
set -euo pipefail

MSG_FILE="${1:-}"
if [[ -z "$MSG_FILE" || ! -f "$MSG_FILE" ]]; then
  echo "commit-msg: missing commit message file" >&2
  exit 1
fi

# First non-comment, non-empty line is the subject
subject="$(grep -vE '^\s*(#|$)' "$MSG_FILE" | head -n1 || true)"
if [[ -z "${subject// }" ]]; then
  echo "commit-msg: empty commit message. Use Conventional Commits (see .gitmessage)." >&2
  exit 1
fi

# Allow merge/revert/fixup commits produced by git itself
if [[ "$subject" =~ ^Merge\  ]] || [[ "$subject" =~ ^Revert\  ]] || [[ "$subject" =~ ^fixup!\  ]] || [[ "$subject" =~ ^squash!\  ]]; then
  exit 0
fi

pattern='^(feat|fix|docs|style|refactor|perf|test|build|ci|chore|revert)(\([a-z0-9._/-]+\))?(!)?: .+'

if ! [[ "$subject" =~ $pattern ]]; then
  cat >&2 <<'ERR'
commit-msg: subject must be a Conventional Commit:

  <type>(<optional-scope>): <summary>

  Types: feat fix docs style refactor perf test build ci chore revert
  Example: feat(cli): add domains subcommand

  Tip: git config commit.template .gitmessage
       (or run: ./scripts/setup-git.sh)
ERR
  exit 1
fi

# Soft length hint (not hard fail beyond 100 — subject often kept ≤72)
if (( ${#subject} > 100 )); then
  echo "commit-msg: warning: subject is ${#subject} chars (prefer ≤72)." >&2
fi

exit 0
